<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.powerloom.ui.ReconciliationController"
            style="-fx-background-color:#F1EFE8;">

    <top>
        <VBox spacing="8">
            <padding><Insets top="10" right="10" bottom="6" left="10"/></padding>

            <!-- ── TOP BAR ─────────────────────────────────────────────────── -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-background-color:white;
                         -fx-background-radius:12;
                         -fx-border-color:#2C2C2A;
                         -fx-border-width:1;
                         -fx-border-radius:12;
                         -fx-padding:10 16 10 16;">

                <Label text="GST Reconciliation"
                       style="-fx-font-size:15px;
                              -fx-font-weight:bold;
                              -fx-text-fill:#2C2C2A;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <!-- ── SEARCH ─────────────────────────────────────────── -->
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <TextField fx:id="searchField"
                               promptText="Search GSTIN, name, invoice…"
                               prefWidth="300"
                               style="-fx-background-radius:8;
                                          -fx-border-radius:8;
                                          -fx-border-color:#2C2C2A;
                                          -fx-border-width:1;
                                          -fx-padding:6 10 6 10;"/>
                    <Button text="Clear" onAction="#onClearSearch"
                            style="-fx-background-color:#F1EFE8;
                                       -fx-border-color:#2C2C2A;
                                       -fx-border-width:1;
                                       -fx-border-radius:8;
                                       -fx-background-radius:8;
                                       -fx-padding:5 12 5 12;
                                       -fx-cursor:hand;"/>
                </HBox>
                <Label text="Month:"
                       style="-fx-font-size:12px;-fx-text-fill:#888780;"/>
                <ComboBox fx:id="monthBox" prefWidth="75"
                          style="-fx-background-radius:8;
                                 -fx-border-color:#2C2C2A;
                                 -fx-border-width:1;
                                 -fx-border-radius:8;"/>
                <Label text="Year:"
                       style="-fx-font-size:12px;-fx-text-fill:#888780;"/>
                <TextField fx:id="yearField" prefWidth="65"
                           style="-fx-background-radius:8;
                                  -fx-border-color:#2C2C2A;
                                  -fx-border-width:1;
                                  -fx-border-radius:8;"/>
                <Label fx:id="monthPill" text="— —"
                       style="-fx-background-color:#E6F1FB;
                              -fx-text-fill:#0C447C;
                              -fx-background-radius:20;
                              -fx-border-color:#378ADD;
                              -fx-border-width:1;
                              -fx-border-radius:20;
                              -fx-padding:3 10 3 10;
                              -fx-font-size:11px;
                              -fx-font-weight:bold;"/>

                <Label fx:id="onlinePill" text="0 online"
                       style="-fx-background-color:#EAF3DE;
                              -fx-text-fill:#27500A;
                              -fx-background-radius:20;
                              -fx-border-color:#639922;
                              -fx-border-width:1;
                              -fx-border-radius:20;
                              -fx-padding:3 10 3 10;
                              -fx-font-size:11px;
                              -fx-font-weight:bold;"/>

                <Label fx:id="tallyPill" text="0 tally"
                       style="-fx-background-color:#FAEEDA;
                              -fx-text-fill:#633806;
                              -fx-background-radius:20;
                              -fx-border-color:#EF9F27;
                              -fx-border-width:1;
                              -fx-border-radius:20;
                              -fx-padding:3 10 3 10;
                              -fx-font-size:11px;
                              -fx-font-weight:bold;"/>

                <Button fx:id="darkToggleBtn" text="Dark mode"
                        onAction="#onToggleDark"
                        style="-fx-background-color:transparent;
                               -fx-text-fill:#2C2C2A;
                               -fx-border-color:#2C2C2A;
                               -fx-border-width:1;
                               -fx-border-radius:8;
                               -fx-background-radius:8;
                               -fx-padding:4 12 4 12;
                               -fx-font-size:12px;
                               -fx-cursor:hand;"/>
            </HBox>

            <!-- ── FILES + SUMMARY ─────────────────────────────────────────── -->
            <HBox spacing="10" alignment="TOP_LEFT">

                <!-- Files card -->
                <VBox spacing="8" HBox.hgrow="ALWAYS"
                      style="-fx-background-color:white;
                             -fx-background-radius:12;
                             -fx-border-color:#2C2C2A;
                             -fx-border-width:1;
                             -fx-border-radius:12;
                             -fx-padding:14;">

                    <Label text="EXCEL FILES"
                           style="-fx-font-size:11px;
                                  -fx-font-weight:bold;
                                  -fx-text-fill:#888780;"/>

                    <!-- ── B2B DROP ZONE ──────────────────────────────────── -->
                    <HBox fx:id="b2bDropZone"
                          spacing="8" alignment="CENTER_LEFT"
                          style="-fx-background-color:#F4F8FD;
                                 -fx-background-radius:8;
                                 -fx-border-color:#2C2C2A;
                                 -fx-border-width:1;
                                 -fx-border-radius:8;
                                 -fx-padding:8 10 8 10;">

                        <Label text="B2B"
                               style="-fx-background-color:#E6F1FB;
                                      -fx-text-fill:#185FA5;
                                      -fx-background-radius:6;
                                      -fx-border-color:#378ADD;
                                      -fx-border-width:1;
                                      -fx-border-radius:6;
                                      -fx-font-size:11px;
                                      -fx-font-weight:bold;
                                      -fx-padding:3 8 3 8;"/>

                        <Label fx:id="b2bDropHint"
                               text="Drop .xlsx here or browse"
                               style="-fx-text-fill:#B4B2A9;
                                      -fx-font-size:11px;
                                      -fx-font-style:italic;"/>

                        <TextField fx:id="b2bPathField"
                                   promptText="B2B (Online) .xlsx"
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-background-color:transparent;
                                          -fx-border-width:0;
                                          -fx-font-size:12px;"/>

                        <Button text="Browse" onAction="#onBrowseB2B"
                                style="-fx-background-color:#E6F1FB;
                                       -fx-text-fill:#185FA5;
                                       -fx-border-color:#2C2C2A;
                                       -fx-border-width:1;
                                       -fx-border-radius:8;
                                       -fx-background-radius:8;
                                       -fx-padding:5 14 5 14;
                                       -fx-font-weight:bold;
                                       -fx-cursor:hand;"/>

                        <Label text="Start row:"
                               style="-fx-font-size:12px;
                                      -fx-text-fill:#888780;"/>

                        <TextField fx:id="b2bStartRow" text="7" prefWidth="52"
                                   style="-fx-background-radius:6;
                                          -fx-border-color:#2C2C2A;
                                          -fx-border-width:1;
                                          -fx-border-radius:6;"/>
                    </HBox>

                    <!-- ── GST DROP ZONE ──────────────────────────────────── -->
                    <HBox fx:id="gstDropZone"
                          spacing="8" alignment="CENTER_LEFT"
                          style="-fx-background-color:#F6F4FE;
                                 -fx-background-radius:8;
                                 -fx-border-color:#2C2C2A;
                                 -fx-border-width:1;
                                 -fx-border-radius:8;
                                 -fx-padding:8 10 8 10;">

                        <Label text="GST"
                               style="-fx-background-color:#E1F5EE;
                                      -fx-text-fill:#0F6E56;
                                      -fx-background-radius:6;
                                      -fx-border-color:#1D9E75;
                                      -fx-border-width:1;
                                      -fx-border-radius:6;
                                      -fx-font-size:11px;
                                      -fx-font-weight:bold;
                                      -fx-padding:3 8 3 8;"/>

                        <Label fx:id="gstDropHint"
                               text="Drop .xlsx here or browse"
                               style="-fx-text-fill:#B4B2A9;
                                      -fx-font-size:11px;
                                      -fx-font-style:italic;"/>

                        <TextField fx:id="gstPathField"
                                   promptText="Tally (GST) .xlsx"
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-background-color:transparent;
                                          -fx-border-width:0;
                                          -fx-font-size:12px;"/>

                        <Button text="Browse" onAction="#onBrowseGST"
                                style="-fx-background-color:#E1F5EE;
                                       -fx-text-fill:#0F6E56;
                                       -fx-border-color:#2C2C2A;
                                       -fx-border-width:1;
                                       -fx-border-radius:8;
                                       -fx-background-radius:8;
                                       -fx-padding:5 14 5 14;
                                       -fx-font-weight:bold;
                                       -fx-cursor:hand;"/>

                        <Label text="Start row:"
                               style="-fx-font-size:12px;
                                      -fx-text-fill:#888780;"/>

                        <TextField fx:id="gstStartRow" text="13" prefWidth="52"
                                   style="-fx-background-radius:6;
                                          -fx-border-color:#2C2C2A;
                                          -fx-border-width:1;
                                          -fx-border-radius:6;"/>
                    </HBox>



                    <!-- ── ACTION BUTTONS ─────────────────────────────────── -->
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Button text="Compare" onAction="#onCompare"
                                style="-fx-background-color:#534AB7;
                                       -fx-text-fill:#EEEDFE;
                                       -fx-background-radius:8;
                                       -fx-border-color:#2C2C2A;
                                       -fx-border-width:1;
                                       -fx-border-radius:8;
                                       -fx-font-weight:bold;
                                       -fx-padding:7 20 7 20;
                                       -fx-cursor:hand;"/>
                        <Button text="Export Excel" onAction="#onExportExcel"
                                style="-fx-background-color:#EAF3DE;
                                       -fx-text-fill:#27500A;
                                       -fx-border-color:#2C2C2A;
                                       -fx-border-width:1;
                                       -fx-border-radius:8;
                                       -fx-background-radius:8;
                                       -fx-padding:7 14 7 14;
                                       -fx-cursor:hand;"/>
                        <Button text="Export PDF" onAction="#onExportPdf"
                                style="-fx-background-color:#FAEEDA;
                                       -fx-text-fill:#633806;
                                       -fx-border-color:#2C2C2A;
                                       -fx-border-width:1;
                                       -fx-border-radius:8;
                                       -fx-background-radius:8;
                                       -fx-padding:7 14 7 14;
                                       -fx-cursor:hand;"/>
                        <Button text="Reset" onAction="#onReset"
                                style="-fx-background-color:#FCEBEB;
                                       -fx-text-fill:#791F1F;
                                       -fx-border-color:#2C2C2A;
                                       -fx-border-width:1;
                                       -fx-border-radius:8;
                                       -fx-background-radius:8;
                                       -fx-padding:7 14 7 14;
                                       -fx-cursor:hand;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <ProgressBar fx:id="progressBar"
                                     prefWidth="180" prefHeight="8"
                                     visible="false"/>
                        <Label fx:id="progressLabel" text=""
                               style="-fx-font-size:11px;-fx-text-fill:#888780;"
                               visible="false"/>
                    </HBox>
                </VBox>

                <!-- ── SUMMARY CARD ───────────────────────────────────────── -->
                <VBox spacing="6" minWidth="225"
                      style="-fx-background-color:white;
                             -fx-background-radius:12;
                             -fx-border-color:#2C2C2A;
                             -fx-border-width:1;
                             -fx-border-radius:12;
                             -fx-padding:14;">

                    <Label text="SUMMARY"
                           style="-fx-font-size:11px;
                                  -fx-font-weight:bold;
                                  -fx-text-fill:#888780;"/>

                    <HBox alignment="CENTER_LEFT"
                          style="-fx-background-color:#E6F1FB;
                                 -fx-border-color:#2C2C2A;
                                 -fx-border-width:0 0 0 4;
                                 -fx-background-radius:0 8 8 0;
                                 -fx-padding:8 12 8 12;">
                        <Label text="Online total"
                               style="-fx-font-size:12px;-fx-font-weight:bold;
                                      -fx-text-fill:#0C447C;"
                               HBox.hgrow="ALWAYS"/>
                        <Label fx:id="totalB2BVal" text="0"
                               style="-fx-font-size:16px;-fx-font-weight:bold;
                                      -fx-text-fill:#0C447C;"/>
                    </HBox>

                    <HBox alignment="CENTER_LEFT"
                          style="-fx-background-color:#EEEDFE;
                                 -fx-border-color:#2C2C2A;
                                 -fx-border-width:0 0 0 4;
                                 -fx-background-radius:0 8 8 0;
                                 -fx-padding:8 12 8 12;">
                        <Label text="Tally total"
                               style="-fx-font-size:12px;-fx-font-weight:bold;
                                      -fx-text-fill:#3C3489;"
                               HBox.hgrow="ALWAYS"/>
                        <Label fx:id="totalGSTVal" text="0"
                               style="-fx-font-size:16px;-fx-font-weight:bold;
                                      -fx-text-fill:#3C3489;"/>
                    </HBox>

                    <HBox alignment="CENTER_LEFT"
                          style="-fx-background-color:#EAF3DE;
                                 -fx-border-color:#2C2C2A;
                                 -fx-border-width:0 0 0 4;
                                 -fx-background-radius:0 8 8 0;
                                 -fx-padding:8 12 8 12;">
                        <Label text="Matched"
                               style="-fx-font-size:12px;-fx-font-weight:bold;
                                      -fx-text-fill:#27500A;"
                               HBox.hgrow="ALWAYS"/>
                        <Label fx:id="matchVal" text="0"
                               style="-fx-font-size:16px;-fx-font-weight:bold;
                                      -fx-text-fill:#27500A;"/>
                    </HBox>

                    <HBox alignment="CENTER_LEFT"
                          style="-fx-background-color:#FCEBEB;
                                 -fx-border-color:#2C2C2A;
                                 -fx-border-width:0 0 0 4;
                                 -fx-background-radius:0 8 8 0;
                                 -fx-padding:8 12 8 12;">
                        <Label text="Mismatch"
                               style="-fx-font-size:12px;-fx-font-weight:bold;
                                      -fx-text-fill:#791F1F;"
                               HBox.hgrow="ALWAYS"/>
                        <Label fx:id="mismatchVal" text="0"
                               style="-fx-font-size:16px;-fx-font-weight:bold;
                                      -fx-text-fill:#791F1F;"/>
                    </HBox>

                    <HBox alignment="CENTER_LEFT"
                          style="-fx-background-color:#FAEEDA;
                                 -fx-border-color:#2C2C2A;
                                 -fx-border-width:0 0 0 4;
                                 -fx-background-radius:0 8 8 0;
                                 -fx-padding:8 12 8 12;">
                        <Label text="Online extra"
                               style="-fx-font-size:12px;-fx-font-weight:bold;
                                      -fx-text-fill:#633806;"
                               HBox.hgrow="ALWAYS"/>
                        <Label fx:id="missingGSTVal" text="0"
                               style="-fx-font-size:16px;-fx-font-weight:bold;
                                      -fx-text-fill:#633806;"/>
                    </HBox>

                    <HBox alignment="CENTER_LEFT"
                          style="-fx-background-color:#FBEAF0;
                                 -fx-border-color:#2C2C2A;
                                 -fx-border-width:0 0 0 4;
                                 -fx-background-radius:0 8 8 0;
                                 -fx-padding:8 12 8 12;">
                        <Label text="Tally extra"
                               style="-fx-font-size:12px;-fx-font-weight:bold;
                                      -fx-text-fill:#72243E;"
                               HBox.hgrow="ALWAYS"/>
                        <Label fx:id="missingB2BVal" text="0"
                               style="-fx-font-size:16px;-fx-font-weight:bold;
                                      -fx-text-fill:#72243E;"/>
                    </HBox>
                </VBox>
            </HBox>

            <!-- ── FILTER CHIPS ─────────────────────────────────────────────── -->
            <HBox spacing="8" alignment="CENTER_LEFT"
                  style="-fx-background-color:white;
                         -fx-background-radius:12;
                         -fx-border-color:#2C2C2A;
                         -fx-border-width:1;
                         -fx-border-radius:12;
                         -fx-padding:10 14 10 14;">

                <Label text="View:"
                       style="-fx-font-size:12px;
                              -fx-font-weight:bold;
                              -fx-text-fill:#444441;"/>

                <ToggleButton fx:id="chip1"
                              text="Match + Mismatch"
                              onAction="#onChip1"/>
                <ToggleButton fx:id="chip2"
                              text="Online – Prev extra"
                              onAction="#onChip2"/>
                <ToggleButton fx:id="chip3"
                              text="Online – Recon month"
                              onAction="#onChip3"/>
                <ToggleButton fx:id="chip4"
                              text="Tally extra"
                              onAction="#onChip4"/>
                <ToggleButton fx:id="chip5"
                              text="Only mismatch"
                              onAction="#onChip5"/>

                <Region HBox.hgrow="ALWAYS"/>


            </HBox>
        </VBox>
    </top>

    <!-- ── TABLE ───────────────────────────────────────────────────────────── -->
    <center>
        <BorderPane style="-fx-padding:0 10 10 10;">
            <center>
                <TableView fx:id="tableView"
                           style="-fx-background-color:white;
                                  -fx-background-radius:12;
                                  -fx-border-color:#2C2C2A;
                                  -fx-border-width:1;
                                  -fx-border-radius:12;">
                    <columns>
                        <TableColumn fx:id="typeCol"
                                     text="Type [Row]"
                                     minWidth="130" sortable="true"/>
                        <TableColumn fx:id="gstinCol"
                                     text="GSTIN"
                                     minWidth="130" sortable="true"/>
                        <TableColumn fx:id="nameCol"
                                     text="Name"
                                     minWidth="140" sortable="true"/>
                        <TableColumn fx:id="invoiceCol"
                                     text="Invoice"
                                     minWidth="100" sortable="true"/>
                        <TableColumn fx:id="dateCol"
                                     text="Date"
                                     minWidth="88"  sortable="true"/>
                        <TableColumn fx:id="taxableCol"
                                     text="Taxable"
                                     minWidth="85"  sortable="true"/>
                        <TableColumn fx:id="igstCol"
                                     text="IGST"
                                     minWidth="75"  sortable="true"/>
                        <TableColumn fx:id="cgstCol"
                                     text="CGST"
                                     minWidth="75"  sortable="true"/>
                        <TableColumn fx:id="sgstCol"
                                     text="SGST"
                                     minWidth="75"  sortable="true"/>
                        <TableColumn fx:id="cessCol"
                                     text="CESS"
                                     minWidth="65"  sortable="true"/>
                    </columns>
                </TableView>
            </center>
        </BorderPane>
    </center>

</BorderPane>