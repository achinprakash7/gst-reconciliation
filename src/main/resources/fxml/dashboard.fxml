<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.BorderPane?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.powerloom.ui.DashboardController">
    <center>
        <TabPane fx:id="tabbedPane" tabClosingPolicy="UNAVAILABLE"
                 style="-fx-background-color:#F1EFE8;">
            <tabs>
                <Tab text="GST Reconciliation" closable="false">
                    <fx:include source="reconciliation.fxml"/>
                </Tab>
            </tabs>
        </TabPane>
    </center>
</BorderPane>